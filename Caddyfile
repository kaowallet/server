# Caddy front for kao-proxy.
# TLS termination + compression only; all routing/upstream logic lives in kao-proxy.
# No access logs anywhere — privacy invariant.

{
	admin off
	email iamwehi@proton.me
}

# `api.kaowallet.com` is the public name the wallet ships as its default
# (`DEFAULT_KAO_SERVER_URL`); `api1` is kept as an explicit node alias. Both
# must have DNS A/AAAA records pointing here for Caddy to provision certs.
api.kaowallet.com, api1.kaowallet.com {
	encode zstd gzip

	reverse_proxy kao-proxy:8080

	# Drop.
	handle {
		respond 404
	}
}
